# DriveDesk environment variables
# Copy to .env.local and fill in values

VITE_APP_NAME=DriveDesk
VITE_APP_URL=http://localhost:5173
VITE_SUPABASE_URL=https://onpeiyzoirtpztulabxy.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_ADMIN_LOGIN=virazh-admin
VITE_ADMIN_PASSWORD=change-this-admin-password
VITE_SUPERADMIN_LOGIN=drivedesk-root
VITE_SUPERADMIN_PASSWORD=change-this-superadmin-password

# Optional local-only variable for applying supabase/DRIVEDESK_FULL_SETUP.sql from terminal.
# Do not expose this in frontend builds.
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Cloudflare Pages deployment (wrangler)
# Set token in environment before running: bash node_modules/.bin/wrangler pages deploy dist
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
