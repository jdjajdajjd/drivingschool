# DriveDesk environment variables
# Copy to .env.local and fill in values

VITE_APP_NAME=DriveDesk
VITE_APP_URL=http://localhost:5173
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional local-only variable for applying supabase/DRIVEDESK_FULL_SETUP.sql from terminal.
# Do not expose this in frontend builds.
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
